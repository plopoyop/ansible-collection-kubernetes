deployment:
  kind: "{{ deployment_kind }}"
service:
  type: "{{ service_type }}"
{% if service_annotations | default({}) != {} %}
  annotations: {{ service_annotations | ansible.builtin.to_json }}
{% endif %}
{% if service_labels | default({}) != {} %}
  labels: {{ service_labels | ansible.builtin.to_json }}
{% endif %}
{% if service_spec | default({}) != {} %}
  spec: {{ service_spec | ansible.builtin.to_json }}
{% endif %}
ports:
{% if traefik_entrypoint_port is defined %}
  traefik:
    port: {{ traefik_entrypoint_port }}
    expose:
      default: {{ traefik_entrypoint_expose }}
{% endif %}
{% if websecure_entrypoint_port is defined %}
  websecure:
    port: {{ websecure_entrypoint_port }}
    exposedPort: {{ websecure_entrypoint_exposed_port }}
    expose:
      default: {{ websecure_entrypoint_expose }}
{% if proxy_protocol_trusted_ips | default([]) | length > 0 %}
    proxyProtocol:
      trustedIPs: {{ proxy_protocol_trusted_ips | ansible.builtin.to_json }}
{% endif %}
{% if forwarded_headers_trusted_ips | default([]) | length > 0 %}
    forwardedHeaders:
      trustedIPs: {{ forwarded_headers_trusted_ips | ansible.builtin.to_json }}
{% endif %}
{% endif %}
{% if websecure_entrypoint_port is defined %}
  web:
    expose:
      default: {{ web_entrypoint_expose }}
{% if proxy_protocol_trusted_ips | default([]) | length > 0 %}
    proxyProtocol:
      trustedIPs: {{ proxy_protocol_trusted_ips | ansible.builtin.to_json }}
{% endif %}
{% if forwarded_headers_trusted_ips | default([]) | length > 0 %}
    forwardedHeaders:
      trustedIPs: {{ forwarded_headers_trusted_ips | ansible.builtin.to_json }}
{% endif %}
{% endif %}
{% for entrypoint in additional_entrypoint | default([]) %}
  {{ entrypoint.name }}:
    port: {{ entrypoint.port }}
    exposedPort: {{ entrypoint.exposed_port }}
    expose:
      default: {{ entrypoint.expose }}
{% endfor %}
{% if dashboard_enabled | default(false) %}
ingressRoute:
  dashboard:
      enabled: true
{% endif %}


{% if traefik_ingress_enabled  | default(true) %}
ingressClass:
  enabled: {{ traefik_ingress_enabled }}
{% endif %}

providers:
  # Disable the Ingress provider (optional)
  kubernetesIngress:
    enabled: {{ traefik_ingress_enabled }}
  # Enable the Gateway API provider
  kubernetesGateway:
    enabled: {{ traefik_gateway_enabled | default(false) }}
{% if traefik_gateway_enabled | default(false) %}
    experimentalChannel: {{ gateway_experimental_channel | default(false) }}
{% if gateway_namespaces | default([]) | length > 0 %}
    namespaces: {{ gateway_namespaces | ansible.builtin.to_json }}
{% endif %}
{% if gateway_cross_provider_namespaces | default([]) | length > 0 %}
    crossProviderNamespaces: {{ gateway_cross_provider_namespaces | ansible.builtin.to_json }}
{% endif %}
{% if gateway_label_selector | default('') | length > 0 %}
    labelSelector: "{{ gateway_label_selector }}"
{% endif %}
{% endif %}

{% if traefik_gateway_enabled | default(false) %}
# Default Gateway exposed by the chart. When no `gateway.listeners` are
# provided, a single `web` HTTP listener accepting routes from all
# namespaces is created so HTTPRoutes work out of the box.
gateway:
  enabled: {{ (gateway | default({})).enabled | default(true) }}
{% if (gateway | default({})).name | default('') | length > 0 %}
  name: "{{ gateway.name }}"
{% endif %}
{% if (gateway | default({})).namespace | default('') | length > 0 %}
  namespace: "{{ gateway.namespace }}"
{% endif %}
{% if (gateway | default({})).annotations | default({}) != {} %}
  annotations: {{ gateway.annotations | ansible.builtin.to_json }}
{% endif %}
{% if (gateway | default({})).infrastructure | default({}) != {} %}
  infrastructure: {{ gateway.infrastructure | ansible.builtin.to_json }}
{% endif %}
{% if (gateway | default({})).defaultScope | default('') | length > 0 %}
  defaultScope: "{{ gateway.defaultScope }}"
{% endif %}
  listeners: {{ (gateway | default({})).listeners | default({"web": {"port": 8000, "protocol": "HTTP", "namespacePolicy": {"from": "All"}}}) | ansible.builtin.to_json }}

gatewayClass:
  enabled: {{ (gateway_class | default({})).enabled | default(true) }}
{% if (gateway_class | default({})).name | default('') | length > 0 %}
  name: "{{ gateway_class.name }}"
{% endif %}
{% if (gateway_class | default({})).labels | default({}) != {} %}
  labels: {{ gateway_class.labels | ansible.builtin.to_json }}
{% endif %}
{% endif %}

{% if (access_logs | default({})).enabled | default(false) %}
accessLog:
  enabled: true
  format: "{{ access_logs.format | default('json') }}"
{% if access_logs.filePath | default(false) %}
  filePath: "{{ access_logs.filePath }}"
{% endif %}
{% if access_logs.bufferingSize | default(false) %}
  bufferingSize: {{ access_logs.bufferingSize }}
{% endif %}
{% if access_logs.filters | default(false) %}
  filters: {{ access_logs.filters | ansible.builtin.to_json }}
{% endif %}
{% if access_logs.fields | default(false) %}
  fields: {{ access_logs.fields | ansible.builtin.to_json }}
{% endif %}
{% endif %}

{% if plugins | default([]) | length > 0 %}
experimental:
  plugins:
{% for plugin in plugins %}
    {{ plugin.name }}:
      moduleName: "{{ plugin.moduleName }}"
      version: "{{ plugin.version }}"
{% endfor %}
{% endif %}

{% if additional_values | default({}) != {} %}
{{ additional_values | ansible.builtin.to_nice_yaml(indent=2) }}
{% endif %}
