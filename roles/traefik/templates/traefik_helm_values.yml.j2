deployment:
  kind: "{{ deployment_kind }}"
service:
  type: "{{ service_type }}"
ports:
{% if traefik_entrypoint_port is defined %}
  traefik:
    port: {{ traefik_entrypoint_port }}
    expose:
      default: {{ traefik_entrypoint_expose }}
{% endif %}
{% if websecure_entrypoint_port is defined %}
  websecure:
    port: {{ websecure_entrypoint_port }}
    exposedPort: {{ websecure_entrypoint_exposed_port }}
    expose:
      default: {{ websecure_entrypoint_expose }}
{% endif %}
{% if websecure_entrypoint_port is defined %}
  web:
    expose:
      default: {{ web_entrypoint_expose }}
{% endif %}
{% for entrypoint in additional_entrypoint | default([]) %}
  {{ entrypoint.name }}:
    port: {{ entrypoint.port }}
    exposedPort: {{ entrypoint.exposed_port }}
    expose:
      default: {{ entrypoint.expose }}
{% endfor %}
{% if dashboard_enabled | default(false) %}
ingressRoute:
  dashboard:
      enabled: true
{% endif %}


{% if traefik_ingress_enabled  | default(true) %}
ingressClass:
  enabled: {{ traefik_ingress_enabled }}
{% endif %}

providers:
  # Disable the Ingress provider (optional)
  kubernetesIngress:
    enabled: {{ traefik_ingress_enabled }}
  # Enable the GatewayAPI provider
  kubernetesGateway:
    enabled: {{ traefik_gateway_enabled }}

# Allow the Gateway to expose HTTPRoute from all namespaces
{% if traefik_gateway_enabled %}
gateway:
  namespacePolicy: All
  listeners:
    web:
      namespacePolicy: All
{% endif %}

{% if (access_logs | default({})).enabled | default(false) %}
logs:
  access:
    enabled: true
    format: "{{ access_logs.format | default('json') }}"
{% if access_logs.filePath | default(false) %}
    filePath: "{{ access_logs.filePath }}"
{% endif %}
{% if access_logs.bufferingSize | default(false) %}
    bufferingSize: {{ access_logs.bufferingSize }}
{% endif %}
{% if access_logs.filters | default(false) %}
    filters: {{ access_logs.filters | to_json }}
{% endif %}
{% if access_logs.fields | default(false) %}
    fields: {{ access_logs.fields | to_json }}
{% endif %}
{% endif %}

{% if plugins | default([]) | length > 0 %}
experimental:
  plugins:
{% for plugin in plugins %}
    {{ plugin.name }}:
      moduleName: "{{ plugin.moduleName }}"
      version: "{{ plugin.version }}"
{% endfor %}
{% endif %}

{% if additional_values | default({}) != {} %}
{{ additional_values | to_nice_yaml(indent=2) }}
{% endif %}
